{
  "name": "cross-window",
  "version": "0.1.0",
  "description": "Query and focus OS windows by PID or window ID with internal platform selection for macOS and Windows.",
  "keywords": [
    "window",
    "focus",
    "macos",
    "native",
    "pid"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test test/platform.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "yarn build && node dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "eslint": "^8.31.0",
    "typescript": "^4.9.5"
  }
}
